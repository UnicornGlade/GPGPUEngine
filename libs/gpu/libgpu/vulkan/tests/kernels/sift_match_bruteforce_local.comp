#version 450

#include <libgpu/vulkan/vk/common.vk>

layout(local_size_x = 64) in;

layout(std430, binding = 0) readonly buffer QueriesIn {
	float queries[];
};

layout(std430, binding = 1) readonly buffer TrainsIn {
	float trains[];
};

layout(std430, binding = 2) writeonly buffer BestIndicesOut {
	uint best_indices[];
};

layout(std430, binding = 3) writeonly buffer BestScoresOut {
	float best_scores[];
};

layout(push_constant) uniform PushConstants {
	uint n_queries;
	uint n_trains;
} params;

const uint kDescriptorDim = 128u;
const uint kTrainTile = 8u;

shared float train_tile[kTrainTile][kDescriptorDim];

void main()
{
	const uint query_index = workSize2DTo1D(gl_GlobalInvocationID);
	const uint local_index = gl_LocalInvocationID.x;
	const bool query_is_active = query_index < params.n_queries;

	float best_score = -3.402823466e38f;
	uint best_index = 0u;

	for (uint train_base = 0u; train_base < params.n_trains; train_base += kTrainTile) {
		for (uint linear_index = local_index; linear_index < kTrainTile * kDescriptorDim; linear_index += gl_WorkGroupSize.x) {
			const uint tile_descriptor = linear_index / kDescriptorDim;
			const uint descriptor_component = linear_index % kDescriptorDim;
			const uint global_train_index = train_base + tile_descriptor;
			train_tile[tile_descriptor][descriptor_component] =
				global_train_index < params.n_trains
					? trains[global_train_index * kDescriptorDim + descriptor_component]
					: 0.0f;
		}
		barrier();

		if (query_is_active) {
			const uint query_offset = query_index * kDescriptorDim;
			const uint tile_size = min(kTrainTile, params.n_trains - train_base);
			for (uint tile_train = 0u; tile_train < tile_size; ++tile_train) {
				float score = 0.0f;
				for (uint component = 0u; component < kDescriptorDim; ++component) {
					score = fma(queries[query_offset + component], train_tile[tile_train][component], score);
				}
				if (score > best_score) {
					best_score = score;
					best_index = train_base + tile_train;
				}
			}
		}
		barrier();
	}

	if (query_is_active) {
		best_indices[query_index] = best_index;
		best_scores[query_index] = best_score;
	}
}
