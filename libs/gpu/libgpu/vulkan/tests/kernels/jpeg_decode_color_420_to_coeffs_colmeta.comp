#version 450

#include <libgpu/vulkan/vk/common.vk>

#include "defines.h"

layout (local_size_x = VK_GROUP_SIZE) in;

layout (std430, binding = 0) readonly buffer DcLutsIn { uint dc_luts[]; };
layout (std430, binding = 1) readonly buffer AcLutsIn { uint ac_luts[]; };
layout (std430, binding = 2) readonly buffer QuantTablesIn { uint quant_tables[]; };
layout (std430, binding = 3) readonly buffer ScanDataIn { uint scan_data[]; };
layout (std430, binding = 4) readonly buffer StartPositionsIn { uint start_positions[]; };
layout (std430, binding = 5) writeonly buffer CoeffsOut { int coeffs_out[]; };
layout (std430, binding = 6) writeonly buffer AllAcZeroFlagsOut { uint all_ac_zero_flags_out[]; };
layout (std430, binding = 7) writeonly buffer ColumnMetaOut { uint column_meta_out[]; };

layout (push_constant) uniform PushConstants {
	uint total_mcus;
	uint y_qtable;
	uint cb_qtable;
	uint cr_qtable;
	uint y_dc_table;
	uint y_ac_table;
	uint cb_dc_table;
	uint cb_ac_table;
	uint cr_dc_table;
	uint cr_ac_table;
} params;

const uint INV_ZIGZAG[64] = uint[](
	0u, 1u, 8u, 16u, 9u, 2u, 3u, 10u,
	17u, 24u, 32u, 25u, 18u, 11u, 4u, 5u,
	12u, 19u, 26u, 33u, 40u, 48u, 41u, 34u,
	27u, 20u, 13u, 6u, 7u, 14u, 21u, 28u,
	35u, 42u, 49u, 56u, 57u, 50u, 43u, 36u,
	29u, 22u, 15u, 23u, 30u, 37u, 44u, 51u,
	58u, 59u, 52u, 45u, 38u, 31u, 39u, 46u,
	53u, 60u, 61u, 54u, 47u, 55u, 62u, 63u
);

struct BitStreamState {
	uint next_word;
	uint cur;
	uint next;
	uint left;
};

void refill(inout BitStreamState state)
{
	if (state.left < 32u) {
		uint w = scan_data[state.next_word];
		w = (w & 0x000000ffu) << 24u
		  | (w & 0x0000ff00u) << 8u
		  | (w & 0x00ff0000u) >> 8u
		  | (w & 0xff000000u) >> 24u;
		state.next_word += 1u;
		state.cur |= w >> state.left;
		state.next = (w << 1u) << (31u - state.left);
		state.left += 32u;
	}
}

void consume(inout BitStreamState state, uint n)
{
	if (n == 0u) return;
	state.cur <<= n;
	state.cur |= (state.next >> 1u) >> (31u - n);
	state.next <<= n;
	state.left -= n;
}

uint peek(BitStreamState state, uint n)
{
	if (n == 0u) return 0u;
	return (state.cur >> 1u) >> (31u - n);
}

uint huffdecodeDc(inout BitStreamState state, uint table_selector)
{
	refill(state);
	uint code = peek(state, 16u);
	uint entry = dc_luts[table_selector * 65536u + code];
	rassert(entry != 0xffffffffu, 213381u);
	consume(state, entry >> 8u);
	return entry & 0xffu;
}

uint huffdecodeAc(inout BitStreamState state, uint table_selector)
{
	refill(state);
	uint code = peek(state, 16u);
	uint entry = ac_luts[table_selector * 65536u + code];
	rassert(entry != 0xffffffffu, 213382u);
	consume(state, entry >> 8u);
	return entry & 0xffu;
}

int huffExtend(int v, uint t)
{
	if (t == 0u) return 0;
	int vt = 1 << int(t - 1u);
	if (v < vt) return v + ((-1) << int(t)) + 1;
	return v;
}

void decodeBlock(
	inout BitStreamState state,
	uint dc_table_selector,
	uint ac_table_selector,
	uint qtable_selector,
	inout int dc_predictor,
	out int coeffs[64],
	out uint all_ac_zero,
	out uint column_meta)
{
	all_ac_zero = 1u;
	uint nonzero_col_mask = 0u;
	uint nonzero_rows_gt0_col_mask = 0u;
	for (uint i = 0u; i < 64u; ++i) coeffs[i] = 0;
	uint dccat = huffdecodeDc(state, dc_table_selector);
	refill(state);
	int diff = int(peek(state, dccat));
	consume(state, dccat);
	dc_predictor += huffExtend(diff, dccat);
	coeffs[0] = dc_predictor * int(quant_tables[qtable_selector * 64u]);
	if (coeffs[0] != 0) {
		nonzero_col_mask |= 1u;
	}
	for (uint pos = 1u; pos < 64u; ++pos) {
		uint rrrrssss = huffdecodeAc(state, ac_table_selector);
		if (rrrrssss == 0u) break;
		if (rrrrssss == 0xf0u) { pos += 15u; continue; }
		uint run = rrrrssss >> 4u;
		uint ssss = rrrrssss & 0x0fu;
		pos += run;
		if (pos >= 64u) break;
		refill(state);
		int value = int(peek(state, ssss));
		consume(state, ssss);
		coeffs[pos] = huffExtend(value, ssss) * int(quant_tables[qtable_selector * 64u + pos]);
		if (coeffs[pos] != 0) {
			all_ac_zero = 0u;
			uint natural = INV_ZIGZAG[pos];
			uint row = natural >> 3u;
			uint col = natural & 7u;
			nonzero_col_mask |= 1u << col;
			if (row > 0u) {
				nonzero_rows_gt0_col_mask |= 1u << col;
			}
		}
	}
	column_meta = nonzero_col_mask | (nonzero_rows_gt0_col_mask << 8u);
}

void storeBlock(uint mcu, uint block, const int coeffs[64], uint all_ac_zero, uint column_meta)
{
	uint block_index = mcu * 6u + block;
	uint base = block_index * 64u;
	for (uint i = 0u; i < 64u; ++i) coeffs_out[base + i] = coeffs[i];
	all_ac_zero_flags_out[block_index] = all_ac_zero;
	column_meta_out[block_index] = column_meta;
}

void main()
{
	uint mcu = workSize2DTo1D(gl_GlobalInvocationID);
	if (mcu >= params.total_mcus) return;

	BitStreamState state;
	state.next_word = start_positions[mcu];
	state.cur = 0u;
	state.next = 0u;
	state.left = 0u;

	int coeffs[64];
	int y_dc = 0;
	int cb_dc = 0;
	int cr_dc = 0;
	uint all_ac_zero = 0u;
	uint column_meta = 0u;

	for (uint block = 0u; block < 4u; ++block) {
		decodeBlock(state, params.y_dc_table, params.y_ac_table, params.y_qtable, y_dc, coeffs, all_ac_zero, column_meta);
		storeBlock(mcu, block, coeffs, all_ac_zero, column_meta);
	}
	decodeBlock(state, params.cb_dc_table, params.cb_ac_table, params.cb_qtable, cb_dc, coeffs, all_ac_zero, column_meta);
	storeBlock(mcu, 4u, coeffs, all_ac_zero, column_meta);
	decodeBlock(state, params.cr_dc_table, params.cr_ac_table, params.cr_qtable, cr_dc, coeffs, all_ac_zero, column_meta);
	storeBlock(mcu, 5u, coeffs, all_ac_zero, column_meta);
}
