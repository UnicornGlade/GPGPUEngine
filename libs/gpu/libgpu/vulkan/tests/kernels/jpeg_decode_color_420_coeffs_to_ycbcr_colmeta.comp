#version 450

#include <libgpu/vulkan/vk/common.vk>

#include "defines.h"

layout (local_size_x = VK_GROUP_SIZE) in;

layout (std430, binding = 0) readonly buffer CoeffsIn { int coeffs_in[]; };
layout (std430, binding = 1) readonly buffer AllAcZeroFlagsIn { uint all_ac_zero_flags_in[]; };
layout (std430, binding = 2) readonly buffer ColumnMetaIn { uint column_meta_in[]; };
layout (std430, binding = 3) writeonly buffer YPlaneOut { uint y_plane[]; };
layout (std430, binding = 4) writeonly buffer CbPlaneOut { uint cb_plane[]; };
layout (std430, binding = 5) writeonly buffer CrPlaneOut { uint cr_plane[]; };

layout (push_constant) uniform PushConstants {
	uint width;
	uint height;
	uint chroma_width;
	uint chroma_height;
	uint mcus_x;
	uint total_mcus;
} params;

const float SCALE[8] = float[](
	1.0, 1.387039845, 1.306562965, 1.175875602,
	1.0, 0.785694958, 0.541196100, 0.275899379
);

const uint ZIGZAG[64] = uint[](
	 0u,  1u,  5u,  6u, 14u, 15u, 27u, 28u,
	 2u,  4u,  7u, 13u, 16u, 26u, 29u, 42u,
	 3u,  8u, 12u, 17u, 25u, 30u, 41u, 43u,
	 9u, 11u, 18u, 24u, 31u, 40u, 44u, 53u,
	10u, 19u, 23u, 32u, 39u, 45u, 52u, 54u,
	20u, 22u, 33u, 38u, 46u, 51u, 55u, 60u,
	21u, 34u, 37u, 47u, 50u, 56u, 59u, 61u,
	35u, 36u, 48u, 49u, 57u, 58u, 62u, 63u
);

uint zigzag(uint pos) { return ZIGZAG[pos]; }

void fillColumn(inout float stage[64], uint col, float value)
{
	for (uint row = 0u; row < 8u; ++row) {
		stage[row * 8u + col] = value;
	}
}

void fillPixelsDcOnly(uint base, out float pixels[64])
{
	float dc_value = clamp(float(coeffs_in[base]) * 0.125 + 128.5, 0.0, 255.0);
	for (uint i = 0u; i < 64u; ++i) {
		pixels[i] = dc_value;
	}
}

void idctBlock(uint mcu, uint block, out float pixels[64])
{
	uint block_index = mcu * 6u + block;
	uint base = block_index * 64u;
	if (all_ac_zero_flags_in[block_index] != 0u) {
		fillPixelsDcOnly(base, pixels);
		return;
	}

	uint column_meta = column_meta_in[block_index];
	uint nonzero_col_mask = column_meta & 0xffu;
	uint nonzero_rows_gt0_col_mask = (column_meta >> 8u) & 0xffu;
	float stage[64];
	for (uint col = 0u; col < 8u; ++col) {
		uint col_bit = 1u << col;
		if ((nonzero_col_mask & col_bit) == 0u) {
			fillColumn(stage, col, 0.0);
			continue;
		}
		if ((nonzero_rows_gt0_col_mask & col_bit) == 0u) {
			float value = float(coeffs_in[base + zigzag(col)]) * SCALE[col] * 0.125;
			fillColumn(stage, col, value);
			continue;
		}
		float inputs[8];
		for (uint row = 0u; row < 8u; ++row) {
			inputs[row] = float(coeffs_in[base + zigzag(row * 8u + col)]) * SCALE[row] * SCALE[col];
		}
		float tmp0 = inputs[0] * 0.125;
		float tmp1 = inputs[2] * 0.125;
		float tmp2 = inputs[4] * 0.125;
		float tmp3 = inputs[6] * 0.125;
		float tmp10 = tmp0 + tmp2;
		float tmp11 = tmp0 - tmp2;
		float tmp13 = tmp1 + tmp3;
		float tmp12 = (tmp1 - tmp3) * 1.414213562 - tmp13;
		float out0 = tmp10 + tmp13;
		float out3 = tmp10 - tmp13;
		float out1 = tmp11 + tmp12;
		float out2 = tmp11 - tmp12;
		float tmp4 = inputs[1] * 0.125;
		float tmp5 = inputs[3] * 0.125;
		float tmp6 = inputs[5] * 0.125;
		float tmp7 = inputs[7] * 0.125;
		float z13 = tmp6 + tmp5;
		float z10 = tmp6 - tmp5;
		float z11 = tmp4 + tmp7;
		float z12 = tmp4 - tmp7;
		float out7 = z11 + z13;
		float tmp11i = (z11 - z13) * 1.414213562;
		float z5 = (z10 + z12) * 1.847759065;
		float tmp10i = z5 - z12 * 1.082392200;
		float tmp12i = z5 - z10 * 2.613125930;
		float out6 = tmp12i - out7;
		float out5 = tmp11i - out6;
		float out4 = tmp10i - out5;
		stage[0u * 8u + col] = out0 + out7;
		stage[7u * 8u + col] = out0 - out7;
		stage[1u * 8u + col] = out1 + out6;
		stage[6u * 8u + col] = out1 - out6;
		stage[2u * 8u + col] = out2 + out5;
		stage[5u * 8u + col] = out2 - out5;
		stage[3u * 8u + col] = out3 + out4;
		stage[4u * 8u + col] = out3 - out4;
	}
	for (uint row = 0u; row < 8u; ++row) {
		float z5 = stage[row * 8u + 0u] + 128.5;
		float tmp10 = z5 + stage[row * 8u + 4u];
		float tmp11 = z5 - stage[row * 8u + 4u];
		float tmp13 = stage[row * 8u + 2u] + stage[row * 8u + 6u];
		float tmp12 = (stage[row * 8u + 2u] - stage[row * 8u + 6u]) * 1.414213562 - tmp13;
		float out0 = tmp10 + tmp13;
		float out3 = tmp10 - tmp13;
		float out1 = tmp11 + tmp12;
		float out2 = tmp11 - tmp12;
		float z13 = stage[row * 8u + 5u] + stage[row * 8u + 3u];
		float z10 = stage[row * 8u + 5u] - stage[row * 8u + 3u];
		float z11 = stage[row * 8u + 1u] + stage[row * 8u + 7u];
		float z12 = stage[row * 8u + 1u] - stage[row * 8u + 7u];
		float out7 = z11 + z13;
		float tmp11i = (z11 - z13) * 1.414213562;
		float z5i = (z10 + z12) * 1.847759065;
		float tmp10i = z5i - z12 * 1.082392200;
		float tmp12i = z5i - z10 * 2.613125930;
		float out6 = tmp12i - out7;
		float out5 = tmp11i - out6;
		float out4 = tmp10i - out5;
		pixels[row * 8u + 0u] = clamp(out0 + out7, 0.0, 255.0);
		pixels[row * 8u + 7u] = clamp(out0 - out7, 0.0, 255.0);
		pixels[row * 8u + 1u] = clamp(out1 + out6, 0.0, 255.0);
		pixels[row * 8u + 6u] = clamp(out1 - out6, 0.0, 255.0);
		pixels[row * 8u + 2u] = clamp(out2 + out5, 0.0, 255.0);
		pixels[row * 8u + 5u] = clamp(out2 - out5, 0.0, 255.0);
		pixels[row * 8u + 3u] = clamp(out3 + out4, 0.0, 255.0);
		pixels[row * 8u + 4u] = clamp(out3 - out4, 0.0, 255.0);
	}
}

void main()
{
	uint mcu = workSize2DTo1D(gl_GlobalInvocationID);
	if (mcu >= params.total_mcus) return;

	uint mcu_x = mcu % params.mcus_x;
	uint mcu_y = mcu / params.mcus_x;
	uint base_x = mcu_x * 16u;
	uint base_y = mcu_y * 16u;
	float pixels[64];

	for (uint block = 0u; block < 4u; ++block) {
		idctBlock(mcu, block, pixels);
		uint bx = block % 2u;
		uint by = block / 2u;
		for (uint ly = 0u; ly < 8u; ++ly) {
			uint y = base_y + by * 8u + ly;
			if (y >= params.height) continue;
			for (uint lx = 0u; lx < 8u; ++lx) {
				uint x = base_x + bx * 8u + lx;
				if (x >= params.width) continue;
				y_plane[y * params.width + x] = uint(pixels[ly * 8u + lx] + 0.5);
			}
		}
	}

	uint chroma_base_x = mcu_x * 8u;
	uint chroma_base_y = mcu_y * 8u;
	idctBlock(mcu, 4u, pixels);
	for (uint ly = 0u; ly < 8u; ++ly) {
		uint y = chroma_base_y + ly;
		if (y >= params.chroma_height) continue;
		for (uint lx = 0u; lx < 8u; ++lx) {
			uint x = chroma_base_x + lx;
			if (x >= params.chroma_width) continue;
			cb_plane[y * params.chroma_width + x] = uint(pixels[ly * 8u + lx] + 0.5);
		}
	}
	idctBlock(mcu, 5u, pixels);
	for (uint ly = 0u; ly < 8u; ++ly) {
		uint y = chroma_base_y + ly;
		if (y >= params.chroma_height) continue;
		for (uint lx = 0u; lx < 8u; ++lx) {
			uint x = chroma_base_x + lx;
			if (x >= params.chroma_width) continue;
			cr_plane[y * params.chroma_width + x] = uint(pixels[ly * 8u + lx] + 0.5);
		}
	}
}
