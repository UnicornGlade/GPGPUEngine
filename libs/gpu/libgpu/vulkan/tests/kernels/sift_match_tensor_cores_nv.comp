#version 450

#extension GL_NV_cooperative_matrix : require
#extension GL_KHR_memory_scope_semantics : enable
#extension GL_EXT_shader_explicit_arithmetic_types_float16 : enable
#extension GL_KHR_shader_subgroup_basic : enable

#include <libgpu/vulkan/vk/common.vk>

layout(local_size_x = 32) in;

layout(std430, binding = 0) readonly buffer QueriesIn {
	float16_t queries[];
};

layout(std430, binding = 1) readonly buffer TrainsIn {
	float16_t trains[];
};

layout(std430, binding = 2) writeonly buffer BestIndicesOut {
	uint best_indices[];
};

layout(std430, binding = 3) writeonly buffer BestScoresOut {
	float best_scores[];
};

layout(std430, binding = 4) writeonly buffer SecondBestIndicesOut {
	uint second_best_indices[];
};

layout(std430, binding = 5) writeonly buffer SecondBestScoresOut {
	float second_best_scores[];
};

layout(push_constant) uniform PushConstants {
	uint n_queries;
	uint n_trains;
} params;

const uint kTileM = 16u;
const uint kTileN = 16u;
const uint kTileK = 16u;
const uint kDescriptorDim = 128u;

shared float score_tile[kTileM * kTileN];

void updateBest2(float score,
				 uint index,
				 inout float best_score,
				 inout uint best_index,
				 inout float second_best_score,
				 inout uint second_best_index)
{
	if (score > best_score) {
		second_best_score = best_score;
		second_best_index = best_index;
		best_score = score;
		best_index = index;
	} else if (index != best_index && score > second_best_score) {
		second_best_score = score;
		second_best_index = index;
	}
}

void main()
{
	const uint subgroup_lane = gl_SubgroupInvocationID;
	const uint tile_row = workGroup2DTo1D(gl_WorkGroupID);
	const uint query_base = tile_row * kTileM;
	const uint query_index = query_base + subgroup_lane;
	const bool query_is_active = subgroup_lane < kTileM && query_index < params.n_queries;

	float best_score = -3.402823466e38f;
	uint best_index = 0u;
	float second_best_score = -3.402823466e38f;
	uint second_best_index = 0u;

	for (uint train_base = 0u; train_base < params.n_trains; train_base += kTileN) {
		fcoopmatNV<32, gl_ScopeSubgroup, kTileM, kTileN> acc =
			fcoopmatNV<32, gl_ScopeSubgroup, kTileM, kTileN>(0.0);

		for (uint k_base = 0u; k_base < kDescriptorDim; k_base += kTileK) {
			fcoopmatNV<16, gl_ScopeSubgroup, kTileM, kTileK> mat_a;
			fcoopmatNV<16, gl_ScopeSubgroup, kTileK, kTileN> mat_b;

			const uint query_offset = query_base * kDescriptorDim + k_base;
			const uint train_offset = train_base * kDescriptorDim + k_base;
			coopMatLoadNV(mat_a, queries, query_offset, kDescriptorDim, false);
			coopMatLoadNV(mat_b, trains, train_offset, kDescriptorDim, true);
			acc = coopMatMulAddNV(mat_a, mat_b, acc);
		}

		coopMatStoreNV(acc, score_tile, 0u, kTileN, false);
		barrier();

		if (query_is_active) {
			const uint tile_size = min(kTileN, params.n_trains - train_base);
			for (uint tile_train = 0u; tile_train < tile_size; ++tile_train) {
				const float score = score_tile[subgroup_lane * kTileN + tile_train];
				updateBest2(score, train_base + tile_train, best_score, best_index, second_best_score, second_best_index);
			}
		}
		barrier();
	}

	if (query_is_active) {
		best_indices[query_index] = best_index;
		best_scores[query_index] = best_score;
		second_best_indices[query_index] = second_best_index;
		second_best_scores[query_index] = second_best_score;
	}
}
