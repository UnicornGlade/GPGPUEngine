#version 450

#include <libgpu/vulkan/vk/common.vk>

layout(local_size_x = 32) in;

layout(std430, binding = 0) readonly buffer QueriesIn {
	uint queries_packed[];
};

layout(std430, binding = 1) readonly buffer TrainsIn {
	uint trains_packed[];
};

layout(std430, binding = 2) writeonly buffer BestIndicesOut {
	uint best_indices[];
};

layout(std430, binding = 3) writeonly buffer BestScoresOut {
	float best_scores[];
};

layout(std430, binding = 4) writeonly buffer SecondBestIndicesOut {
	uint second_best_indices[];
};

layout(std430, binding = 5) writeonly buffer SecondBestScoresOut {
	float second_best_scores[];
};

layout(push_constant) uniform PushConstants {
	uint n_queries;
	uint n_trains;
} params;

const uint kDescriptorPacked = 64u;
const uint kTrainTile = 64u;

shared uint train_tile[kTrainTile][kDescriptorPacked];

void updateBest2(float score,
				 uint index,
				 inout float best_score,
				 inout uint best_index,
				 inout float second_best_score,
				 inout uint second_best_index)
{
	if (score > best_score) {
		second_best_score = best_score;
		second_best_index = best_index;
		best_score = score;
		best_index = index;
	} else if (index != best_index && score > second_best_score) {
		second_best_score = score;
		second_best_index = index;
	}
}

void main()
{
	const uint query_index = workSize2DTo1D(gl_GlobalInvocationID);
	const uint local_index = gl_LocalInvocationID.x;
	const bool query_is_active = query_index < params.n_queries;

	uint query_registers[kDescriptorPacked];
	if (query_is_active) {
		const uint query_offset = query_index * kDescriptorPacked;
		for (uint component2 = 0u; component2 < kDescriptorPacked; ++component2) {
			query_registers[component2] = queries_packed[query_offset + component2];
		}
	} else {
		for (uint component2 = 0u; component2 < kDescriptorPacked; ++component2) {
			query_registers[component2] = 0u;
		}
	}

	float best_score = -3.402823466e38f;
	uint best_index = 0u;
	float second_best_score = -3.402823466e38f;
	uint second_best_index = 0u;

	for (uint train_base = 0u; train_base < params.n_trains; train_base += kTrainTile) {
		for (uint linear_index = local_index; linear_index < kTrainTile * kDescriptorPacked; linear_index += gl_WorkGroupSize.x) {
			const uint tile_train = linear_index / kDescriptorPacked;
			const uint component2 = linear_index % kDescriptorPacked;
			const uint global_train_index = train_base + tile_train;
			train_tile[tile_train][component2] =
				global_train_index < params.n_trains
					? trains_packed[global_train_index * kDescriptorPacked + component2]
					: 0u;
		}
		barrier();

		if (query_is_active) {
			const uint tile_size = min(kTrainTile, params.n_trains - train_base);
			for (uint tile_train = 0u; tile_train < tile_size; ++tile_train) {
				float score = 0.0f;
				for (uint component2 = 0u; component2 < kDescriptorPacked; ++component2) {
					score += dot(unpackHalf2x16(query_registers[component2]),
								 unpackHalf2x16(train_tile[tile_train][component2]));
				}
				updateBest2(score, train_base + tile_train, best_score, best_index, second_best_score, second_best_index);
			}
		}
		barrier();
	}

	if (query_is_active) {
		best_indices[query_index] = best_index;
		best_scores[query_index] = best_score;
		second_best_indices[query_index] = second_best_index;
		second_best_scores[query_index] = second_best_score;
	}
}
